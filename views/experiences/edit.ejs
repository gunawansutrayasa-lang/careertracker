<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Experience — CareerTracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root { --ct-bg: #fafafa; --ct-surface: #ffffff; --ct-border: #eeeeee; --ct-text-main: #0a0a0a; --ct-text-muted: #666666; --ct-accent: #000000; --ct-radius: 8px; --ct-radius-sm: 6px; }
        body { background-color: var(--ct-bg); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--ct-text-main); }
        .ct-main-center { max-width: 600px; margin: 80px auto; padding: 0 24px; }
        .card-saas { background: var(--ct-surface); border: 1px solid var(--ct-border); border-radius: var(--ct-radius); padding: 32px; }
        .form-control-saas { background-color: var(--ct-bg); border: 1px solid var(--ct-border); border-radius: var(--ct-radius-sm); font-size: 0.9rem; padding: 10px 14px; margin-bottom: 20px; }
        .btn-premium { background-color: var(--ct-accent); color: #ffffff; border-radius: var(--ct-radius-sm); font-size: 0.875rem; padding: 10px 20px; border: 1px solid var(--ct-accent); text-decoration: none; font-weight: 500; }
        .btn-cancel { border: 1px solid var(--ct-border); background: none; color: var(--ct-text-muted); padding: 10px 20px; border-radius: var(--ct-radius-sm); text-decoration: none; font-size: 0.875rem; }
    </style>
</head>
<body>
    <div class="ct-main-center">
        <div class="mb-4">
            <a href="/experiences" class="btn-cancel px-3 py-1.5 small"><i data-lucide="arrow-left" style="width:14px; height:14px; vertical-align:middle;"></i> Back</a>
            <h3 class="fw-bold m-0 mt-4">Modify Experience Record</h3>
        </div>
        <div class="card-saas">
            <form method="POST" action="/experiences/<%= experience.id %>/update">
                <label class="small fw-semibold text-muted mb-2">Job Title / Position</label>
                <input type="text" name="title" value="<%= experience.title %>" class="form-control form-control-saas" required>

                <label class="small fw-semibold text-muted mb-2">Company / Institution Name</label>
                <input type="text" name="company_name" value="<%= experience.company_name %>" class="form-control form-control-saas" required>

                <label class="small fw-semibold text-muted mb-2">Location (Optional)</label>
                <input type="text" name="location" value="<%= experience.location %>" class="form-control form-control-saas">

                <div class="row">
                    <div class="col-md-6">
                        <label class="small fw-semibold text-muted mb-2">Start Date</label>
                        <input type="date" name="start_date" value="<%= experience.start_date ? new Date(experience.start_date).toISOString().split('T')[0] : '' %>" class="form-control form-control-saas" required>
                    </div>
                    <div class="col-md-6">
                        <label class="small fw-semibold text-muted mb-2">End Date</label>
                        <input type="date" name="end_date" id="end_date" value="<%= experience.end_date ? new Date(experience.end_date).toISOString().split('T')[0] : '' %>" class="form-control form-control-saas" <%= experience.is_current ? 'disabled' : '' %>>
                    </div>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" name="is_current" id="is_current" value="1" <%= experience.is_current ? 'checked' : '' %> onchange="document.getElementById('end_date').disabled = this.checked;">
                    <label class="form-check-label small fw-semibold text-muted" for="is_current">
                        I am currently working in this role
                    </label>
                </div>

                <label class="small fw-semibold text-muted mb-2">Role Description / Core Responsibilities</label>
                <textarea name="description" class="form-control form-control-saas" rows="4"><%= experience.description %></textarea>

                <div class="d-flex justify-content-end gap-3">
                    <a href="/experiences" class="btn-cancel">Cancel Modification</a>
                    <button type="submit" class="btn-premium">Commit Changes</button>
                </div>
            </form>
        </div>
    </div>
    <script>lucide.createIcons();</script>
</body>
</html>