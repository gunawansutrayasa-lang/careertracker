<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Skills Registry — CareerTracker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root { --ct-bg: #fafafa; --ct-surface: #ffffff; --ct-border: #eeeeee; --ct-text-main: #0a0a0a; --ct-text-muted: #666666; --ct-accent: #000000; --ct-radius: 8px; --ct-radius-sm: 6px; }
        body { background-color: var(--ct-bg); font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color: var(--ct-text-main); }
/* --- LAYOUT STRUCTURE & COLLAPSIBLE SIDEBAR --- */
        .ct-sidebar { 
            background-color: var(--ct-surface);
            border-right: 1px solid var(--ct-border); 
            height: 100vh; 
            position: fixed; 
            width: 240px; /* Lebar default saat terbuka */
            top: 0; 
            left: 0; 
            padding: 24px 16px; 
            display: flex;
            flex-direction: column;
            transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), padding 0.3s ease;
            z-index: 1000;
        }

        .ct-main { 
            margin-left: 240px; /* Jarak default dari sidebar */
            padding: 40px 56px; 
            transition: margin-left 0.3s cubic-bezier(0.4, 0, 0.2, 1); /* Pergeseran halaman halus */
        }

        /* --- STATE KETIKA SIDEBAR MENGECIL (COLLAPSED) --- */
        .ct-sidebar.collapsed {
            width: 75px; /* Lebar mini hanya muat ikon */
            padding: 24px 12px;
        }

        .ct-main.sidebar-collapsed {
            margin-left: 75px; /* Konten otomatis maju ke kiri mengikuti sidebar */
        }

        /* Sembunyikan semua teks berlabel .sidebar-text secara total */
        .ct-sidebar.collapsed .sidebar-text {
            display: none !important;
        }

        /* Penyesuaian header logo & tombol hamburger saat mengecil */
        .ct-sidebar.collapsed .dashboard-header-box {
            justify-content: center !important;
        }
        .ct-sidebar.collapsed .ct-brand {
            display: none !important;
        }

        /* Penyesuaian item menu navigasi agar presisi di tengah */
        .ct-sidebar.collapsed .ct-nav-item {
            justify-content: center;
            padding: 10px 0;
            gap: 0;
        }
        .ct-sidebar.collapsed .ct-nav-item i {
            margin: 0 !important;
        }

        /* Penyesuaian tombol profil bulat di bawah */
        .ct-sidebar.collapsed .dropup button {
            justify-content: center !important;
            padding: 8px 0 !important;
        }
        
        /* Menjaga agar pop-up menu upload foto tetap lebar & proporsional saat diklik */
        .ct-sidebar.collapsed .compact-menu {
            min-width: 210px !important;
        }

        .ct-brand { font-size: 1.1rem; font-weight: 700; display: flex; align-items: center; gap: 10px; letter-spacing: -0.03em; }
        .ct-nav-item { color: var(--ct-text-muted); border-radius: var(--ct-radius-sm); padding: 10px 12px; display: flex; align-items: center; gap: 12px; text-decoration: none; margin-bottom: 4px; font-size: 0.9rem; font-weight: 500; }
        .ct-nav-item:hover { background-color: #f5f5f5; color: var(--ct-text-main); }
        .ct-nav-item.active { background-color: #000000; color: #ffffff; }
        .card-saas { background: var(--ct-surface); border: 1px solid var(--ct-border); border-radius: var(--ct-radius); padding: 0; overflow: hidden; }
        .form-control-saas { background-color: var(--ct-bg); border: 1px solid var(--ct-border); border-radius: var(--ct-radius-sm); font-size: 0.85rem; padding: 8px 12px; }
        .ct-table { width: 100%; margin-bottom: 0; vertical-align: middle; }
        .ct-table th { font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ct-text-muted); padding: 14px 16px; border-bottom: 1px solid var(--ct-border); background: #fafafa; }
        .ct-table td { padding: 16px; font-size: 0.9rem; border-bottom: 1px solid var(--ct-border); }
        .btn-premium { background-color: var(--ct-accent); color: #ffffff; border-radius: var(--ct-radius-sm); font-size: 0.875rem; padding: 8px 16px; border: 1px solid var(--ct-accent); display: inline-flex; align-items: center; gap: 8px; text-decoration: none; }
        .btn-action-outline { border: 1px solid var(--ct-border); background: #fff; color: var(--ct-text-muted); padding: 6px 10px; border-radius: var(--ct-radius-sm); display: inline-flex; text-decoration: none; }
        .btn-action-outline:hover { border-color: #a3a3a3; color: var(--ct-text-main); }
        /* Styling untuk membuat menu profil lebih compact */
        .compact-menu {
            padding: 0.5rem 0 !important;
            font-size: 0.85rem !important;
        }

        .compact-menu .dropdown-item {
            padding: 0.4rem 1rem !important; /* Memperkecil padding item */
        }

        .compact-menu .dropdown-divider {
            margin: 0.25rem 0 !important; /* Memperkecil jarak garis pemisah */
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>

<div class="ct-sidebar" id="sidebar">
        <div class="d-flex align-items-center justify-content-between px-2 mb-5 dashboard-header-box">
            <div class="ct-brand">
                <i data-lucide="box"></i> 
                <span class="sidebar-text">CareerTracker</span>
            </div>
            <button class="btn p-1 border-0" id="sidebarToggle" style="color: var(--ct-text-main); display: flex; align-items: center;">
                <i data-lucide="menu" style="width: 20px; height: 20px;"></i>
            </button>
        </div>

        <div class="nav flex-column">
            <a href="/" class="ct-nav-item"><i data-lucide="grid"></i> <span class="sidebar-text">Console Overview</span></a>
            <a href="/projects" class="ct-nav-item"><i data-lucide="folder-kanban"></i> <span class="sidebar-text">Projects Engine</span></a>
            <a href="/organizations" class="ct-nav-item"><i data-lucide="globe"></i> <span class="sidebar-text">Organizations</span></a>
            <a href="/experiences" class="ct-nav-item"><i data-lucide="activity"></i> <span class="sidebar-text">Experiences</span></a>
            <a href="/achievements" class="ct-nav-item"><i data-lucide="shield-check"></i> <span class="sidebar-text">Achievements</span></a>
            <a href="/certificates" class="ct-nav-item"><i data-lucide="layers"></i> <span class="sidebar-text">Certificates</span></a>
            <a href="/skills" class="ct-nav-item"><i data-lucide="cpu"></i> <span class="sidebar-text">Skills Registry</span></a>
        </div>

        <div class="mt-auto px-0">
            <div class="dropup w-100">
                <button class="btn btn-light w-100 d-flex align-items-center border-0 p-2 text-start" data-bs-toggle="dropdown" aria-expanded="false">
                    <img src="<%= user.avatar ? '/uploads/profiles/' + user.avatar : 'https://ui-avatars.com/api/?name=' + user.username %>" 
                        class="rounded-circle" width="32" height="32" style="object-fit: cover; min-width: 32px; min-height: 32px;">
                    <div class="sidebar-text ms-2" style="font-size: 0.85rem; overflow: hidden;">
                        <div class="fw-bold"><%= user.username %></div>
                        <div class="text-muted" style="font-size: 0.7rem;">Account Settings</div>
                    </div>
                </button>
                
                <ul class="dropdown-menu dropdown-menu-end w-100 mb-2 compact-menu shadow-sm">
                    <li>
                        <form action="/profile/upload" method="POST" enctype="multipart/form-data" class="px-3 py-1">
                            <small class="text-muted d-block mb-1">Update Avatar</small>
                            <input type="file" name="avatar" class="form-control form-control-sm mb-2" accept="image/*" required>
                            <button type="submit" class="btn btn-dark btn-sm w-100">Upload</button>
                        </form>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item text-danger" href="/logout">
                            <i data-lucide="log-out" class="me-2" style="width:14px"></i> Sign Out
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="ct-main" id="mainContent">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h2 class="fw-bold m-0 mb-1">Skills Registry</h2>
                <p class="text-muted m-0" style="font-size: 0.95rem;">Map technical proficiencies, core competencies, and skill stacks.</p>
            </div>
            <a href="/skills/new" class="btn-premium"><i data-lucide="plus"></i> Add New Skill</a>
        </div>

        <% if (success) { %>
            <div class="alert alert-success border-0 small mb-4 py-3" style="background-color: #f1fcf5; color: #0e703c; border-radius: var(--ct-radius-sm); font-weight: 500;"><%= success %></div>
        <% } %>

        <div class="card-saas p-4 mb-4" style="background-color: #ffffff;">
            <form method="GET" action="/skills" class="row g-3 align-items-end">
                <div class="col-md-9">
                    <label class="small fw-semibold text-muted mb-2">Filter Matrix</label>
                    <input type="text" name="search" value="<%= search %>" class="form-control form-control-saas" placeholder="Query skill label or stack category...">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn-premium w-100 justify-content-center"><i data-lucide="sliders-horizontal"></i> Sync Registry</button>
                </div>
            </form>
        </div>

        <div class="card-saas">
            <div class="table-responsive">
                <table class="table ct-table">
                    <thead>
                        <tr>
                            <th>Skill Name</th>
                            <th>Stack Category</th>
                            <th>Proficiency Tier</th>
                            <th>Cluster Owner</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(skills.length === 0) { %>
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted small">No technical competencies indexed in core cluster.</td>
                            </tr>
                        <% } else { %>
                            <% skills.forEach(skill => { %>
                                <tr>
                                    <td class="fw-semibold text-dark"><%= skill.name %></td>
                                    <td><span class="badge bg-secondary-subtle text-secondary border px-2 py-1"><%= skill.category %></span></td>
                                    <td>
                                        <% if(skill.proficiency_level === 'Expert') { %>
                                            <span class="badge text-bg-dark px-2 py-1">Expert Level</span>
                                        <% } else if(skill.proficiency_level === 'Advanced') { %>
                                            <span class="badge text-bg-primary px-2 py-1">Advanced Tier</span>
                                        <% } else if(skill.proficiency_level === 'Intermediate') { %>
                                            <span class="badge text-bg-success px-2 py-1">Intermediate</span>
                                        <% } else { %>
                                            <span class="badge text-bg-light border px-2 py-1">Beginner Core</span>
                                        <% } %>
                                    </td>
                                    <td class="text-muted small">@<%= skill.username %></td>
                                    <td class="text-end">
                                        <div class="d-inline-flex gap-2">
                                            <a href="/skills/<%= skill.id %>/edit" class="btn-action-outline"><i data-lucide="edit-3" style="width:14px; height:14px;"></i></a>
                                            <form method="POST" action="/skills/<%= skill.id %>/delete" onsubmit="return confirm('Purge skill asset?');" style="display:inline;">
                                                <button type="submit" class="btn-action-outline text-danger" style="background:none;"><i data-lucide="trash-2" style="width:14px; height:14px;"></i></button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <% if(totalPages > 1) { %>
                <div class="p-4 border-top d-flex justify-content-between align-items-center bg-light-subtle">
                    <span class="small text-muted">Page <%= page %> of <%= totalPages %></span>
                    <div class="d-inline-flex gap-2">
                        <% if(page > 1) { %>
                            <a href="/skills?page=<%= page - 1 %>&search=<%= search %>" class="btn-action-outline">Previous</a>
                        <% } %>
                        <% if(page < totalPages) { %>
                            <a href="/skills?page=<%= page + 1 %>&search=<%= search %>" class="btn-action-outline">Next</a>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <script>lucide.createIcons();</script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const sidebar = document.getElementById("sidebar");
            const mainContent = document.getElementById("mainContent");
            const toggleBtn = document.getElementById("sidebarToggle");

            // 1. Ambil status mengecil/membesar terakhir dari memori browser (localStorage)
            if (localStorage.getItem("sidebarStatus") === "collapsed") {
                if (sidebar) sidebar.classList.add("collapsed");
                if (mainContent) mainContent.classList.add("sidebar-collapsed");
            }

            // 2. Logika eksekusi klik tombol hamburger
            if (toggleBtn) {
                toggleBtn.addEventListener("click", function() {
                    sidebar.classList.toggle("collapsed");
                    mainContent.classList.toggle("sidebar-collapsed");
                    
                    if (sidebar.classList.contains("collapsed")) {
                        localStorage.setItem("sidebarStatus", "collapsed");
                    } else {
                        localStorage.setItem("sidebarStatus", "expanded");
                    }
                });
            }

            // 3. FITUR BARU: OTOMATIS HIGHLIGHT MENU SESUAI URL AKTIF
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('.ct-nav-item');
            
            navLinks.forEach(link => {
                const href = link.getAttribute('href');
                
                // Kondisi A: Jika URL pas cocok (Contoh: / atau /projects)
                // Kondisi B: Untuk sub-menu (Contoh jika buka /projects/new, menu /projects tetap menyala)
                if (currentPath === href || (href !== '/' && currentPath.startsWith(href))) {
                    link.classList.add('active');
                } else {
                    link.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>