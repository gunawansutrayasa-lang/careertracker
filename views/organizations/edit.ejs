<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Organization — CareerTracker</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      :root {
        --ct-bg: #fafafa;
        --ct-surface: #ffffff;
        --ct-border: #eeeeee;
        --ct-text-main: #0a0a0a;
        --ct-text-muted: #666666;
        --ct-accent: #000000;
        --ct-radius: 8px;
        --ct-radius-sm: 6px;
      }
      body {
        background-color: var(--ct-bg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ct-text-main);
      }
      .ct-main-center {
        max-width: 600px;
        margin: 80px auto;
        padding: 0 24px;
      }
      .card-saas {
        background: var(--ct-surface);
        border: 1px solid var(--ct-border);
        border-radius: var(--ct-radius);
        padding: 32px;
      }
      .form-control-saas {
        background-color: var(--ct-bg);
        border: 1px solid var(--ct-border);
        border-radius: var(--ct-radius-sm);
        font-size: 0.9rem;
        padding: 10px 14px;
        margin-bottom: 20px;
      }
      .btn-premium {
        background-color: var(--ct-accent);
        color: #ffffff;
        border-radius: var(--ct-radius-sm);
        font-size: 0.875rem;
        padding: 10px 20px;
        border: 1px solid var(--ct-accent);
        text-decoration: none;
        font-weight: 500;
      }
      .btn-cancel {
        border: 1px solid var(--ct-border);
        background: none;
        color: var(--ct-text-muted);
        padding: 10px 20px;
        border-radius: var(--ct-radius-sm);
        text-decoration: none;
        font-size: 0.875rem;
      }
    </style>
  </head>
  <body>
    <div class="ct-main-center">
      <div class="mb-4">
        <a href="/organizations" class="btn-cancel px-3 py-1.5 small"
          ><i
            data-lucide="arrow-left"
            style="width: 14px; height: 14px; vertical-align: middle"
          ></i>
          Back</a
        >
        <h3 class="fw-bold m-0 mt-4">Edit Organization</h3>
      </div>
      <div class="card-saas">
        <form
          method="POST"
          action="/organizations/<%= organization.id %>/update"
        >
          <label class="small fw-semibold text-muted mb-2"
            >Organization Name</label
          >
          <input
            type="text"
            name="org_name"
            value="<%= organization.org_name %>"
            class="form-control form-control-saas"
            required
          />

          <label class="small fw-semibold text-muted mb-2"
            >Your Role / Position</label
          >
          <input
            type="text"
            name="role"
            value="<%= organization.role %>"
            class="form-control form-control-saas"
            required
          />

          <label class="small fw-semibold text-muted mb-2"
            >Industry Sector</label
          >
          <input
            type="text"
            name="industry"
            value="<%= organization.industry %>"
            class="form-control form-control-saas"
          />

          <label class="small fw-semibold text-muted mb-2">Description</label>
          <textarea
            name="description"
            class="form-control form-control-saas"
            rows="4"
          >
<%= organization.description %></textarea
          >

          <div class="d-flex justify-content-end gap-3">
            <a href="/organizations" class="btn-cancel">Cancel</a>
            <button type="submit" class="btn-premium">Update Record</button>
          </div>
        </form>
      </div>
    </div>
    <script>
      lucide.createIcons();
    </script>
  </body>
</html>
