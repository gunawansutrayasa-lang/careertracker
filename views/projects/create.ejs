<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Configure Deployment — CareerTracker</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
      :root {
        --ct-bg: #fafafa;
        --ct-surface: #ffffff;
        --ct-border: #eeeeee;
        --ct-text-main: #0a0a0a;
        --ct-text-muted: #666666;
        --ct-accent: #000000;
        --ct-radius: 8px;
        --ct-radius-sm: 6px;
      }
      body {
        background-color: var(--ct-bg);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--ct-text-main);
      }
      .ct-main-center {
        max-width: 600px;
        margin: 80px auto;
        padding: 0 24px;
      }
      .card-saas {
        background: var(--ct-surface);
        border: 1px solid var(--ct-border);
        border-radius: var(--ct-radius);
        padding: 32px;
      }
      .form-control-saas,
      .form-select-saas {
        background-color: var(--ct-bg);
        border: 1px solid var(--ct-border);
        border-radius: var(--ct-radius-sm);
        font-size: 0.9rem;
        padding: 10px 14px;
        color: var(--ct-text-main);
        margin-bottom: 20px;
      }
      .btn-premium {
        background-color: var(--ct-accent);
        color: #ffffff;
        border-radius: var(--ct-radius-sm);
        font-size: 0.875rem;
        padding: 10px 20px;
        border: 1px solid var(--ct-accent);
        display: inline-flex;
        align-items: center;
        gap: 8px;
        text-decoration: none;
        font-weight: 500;
      }
      .btn-premium:hover {
        background-color: #1a1a1a;
      }
      .btn-cancel {
        border: 1px solid var(--ct-border);
        background: none;
        color: var(--ct-text-muted);
        padding: 10px 20px;
        border-radius: var(--ct-radius-sm);
        text-decoration: none;
        font-size: 0.875rem;
      }
      .btn-cancel:hover {
        color: #000;
        border-color: #a3a3a3;
      }
    </style>
  </head>
  <body>
    <div class="ct-main-center">
      <div class="mb-4">
        <a href="/projects" class="btn-cancel px-3 py-1.5 small"
          ><i
            data-lucide="arrow-left"
            style="width: 14px; height: 14px; vertical-align: middle"
          ></i>
          System Catalog</a
        >
        <h3 class="fw-bold m-0 mt-4">Deploy Asset Mapping</h3>
        <p class="text-muted small m-0 mt-1">
          Inject programmatic validation structures straight into core
          architecture tables.
        </p>
      </div>

      <div class="card-saas">
        <form method="POST" action="/projects">
          <label class="small fw-semibold text-muted mb-2"
            >Project Display Identifier Name</label
          >
          <input
            type="text"
            name="project_name"
            class="form-control form-control-saas"
            required
            placeholder="e.g., Enterprise Architecture Pipeline"
          />

          <div class="row">
            <div class="col-md-6">
              <label class="small fw-semibold text-muted mb-2"
                >Architecture Cluster Taxonomy</label
              >
              <select
                name="category"
                class="form-select form-select-saas"
                required
              >
                <option value="Web">Web Cluster</option>
                <option value="Mobile">Mobile Cluster</option>
                <option value="IoT">IoT Cluster</option>
              </select>
            </div>
            <div class="col-md-6">
              <label class="small fw-semibold text-muted mb-2"
                >Lifecycle Status Flag</label
              >
              <select
                name="status"
                class="form-select form-select-saas"
                required
              >
                <option value="Ongoing">Ongoing Development</option>
                <option value="Completed">Completed Lifecycle</option>
              </select>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6">
              <label class="small fw-semibold text-muted mb-2"
                >Initialization Timeline Date</label
              >
              <input
                type="date"
                name="start_date"
                class="form-control form-control-saas"
                required
              />
            </div>
            <div class="col-md-6">
              <label class="small fw-semibold text-muted mb-2"
                >Finalization Timeline Date</label
              >
              <input
                type="date"
                name="end_date"
                class="form-control form-control-saas"
                required
              />
            </div>
          </div>

          <label class="small fw-semibold text-muted mb-2"
            >System Infrastructure Description Metadata (Optional)</label
          >
          <textarea
            name="description"
            class="form-control form-control-saas"
            rows="4"
            placeholder="Optional system parameters and operational scope notes..."
          ></textarea>

          <div class="d-flex justify-content-end gap-3 mt-2">
            <a href="/projects" class="btn-cancel">Abort Entry</a>
            <button type="submit" class="btn-premium">
              Commit Data Record
            </button>
          </div>
        </form>
      </div>
    </div>

    <script>
      lucide.createIcons();
    </script>
  </body>
</html>
